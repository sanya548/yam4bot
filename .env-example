# Telegram bot token from BotFather.
TG_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# Yandex Music token, see https://yandex-music.readthedocs.io/en/main/token.html
YAM_TOKEN="YOUR_YANDEX_MUSIC_TOKEN"

# Chat ID for the dump chat (private group) used to pre-upload audio files.
DUMP_CHAT_ID="-000000000"

# Comma- or space-separated list of allowed Telegram user IDs.
# If empty, the bot will not respond to anyone.
ALLOWED_USER_IDS="123456789,987654321"

# SQLite database path.
DB_PATH="./data/bot.db"

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (or a numeric value).
LOG_LEVEL="INFO"
